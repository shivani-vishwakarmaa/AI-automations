      "parameters": {
        "functionCode": "// 1. Capture the content from any possible LLM output key\nconst rawContent = $json.text || $json.response || $json.output || \"\";\n\n// 2. Clean the string:\n// - .trim() removes leading/trailing spaces and newlines\n// - .replace() collapses 3+ consecutive newlines into a clean double-space\nconst cleanBlog = rawContent\n  .trim()\n  .replace(/\\n{3,}/g, '\\n\\n');\n\n// 3. Return the sanitized result\nreturn {\n  blog: cleanBlog,\n  wordCount: cleanBlog.split(/\\s+/).filter(word => word.length > 0).length\n};"
      },
      "id": "335559cb-907b-4c18-b46c-bff93857686a",
      "name": "Extract: Draft Content\t",
      "type": "n8n-nodes-base.function",
      "position": [
        2128,
        -64
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const fullBlog = $json.blog || \"\";\nconst lines = fullBlog.split('\\n');\n\n// The first line starting with '#' is usually your title\nconst title = lines[0].replace(/^#\\s+/, '').trim(); \nconst body = lines.slice(1).join('\\n').trim();\n\nreturn {\n  title: title,\n  body: body,\n  wordCount: $json.wordCount\n};"
      },
      "type": "n8n-nodes-base.code",
