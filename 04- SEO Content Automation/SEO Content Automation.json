    {
      "parameters": {
        "promptType": "define",
        "text": "=Act as a Content Strategist for {{ $node[\"Brand Config\"].json[\"brand\"] }}. \nNiche: {{ $node[\"Brand Config\"].json[\"niche\"] }}.\n\nTarget Keywords:\n- Primary: {{ $json.primary }}\n- Secondary: {{ $json.secondary.join(\", \") }}\n\nTask: Create a detailed SEO blog outline that follows Google's EEAT guidelines.\nOutput: Return ONLY a JSON object. No intro/outro text.\n\n{\n  \"title\": \"A compelling, high-CTR headline including the primary keyword\",\n  \"meta_description\": \"A 150-160 character meta description for Google search\",\n  \"outline\": [\n    \"Introduction: Hook, problem statement, and solution overview\",\n    \"H2: Why [Primary Keyword] matters for B2B Growth\",\n    \"H2: Key benefits of AI Automation in [Niche]\",\n    \"H3: Sub-point using secondary keywords\",\n    \"H2: Implementation strategy and real-world examples\",\n    \"Conclusion: Summary and CTA for {{ $node[\"Brand Config\"].json[\"brand\"] }}\"\n  ]\n}",
        "hasOutputParser": true,
        "batching": {}
