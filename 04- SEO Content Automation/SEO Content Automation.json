      "parameters": {
        "promptType": "define",
        "text": "=Act as a Senior B2B Content Marketer and AI Automation Expert for {{ $node[\"Brand Config\"].json[\"brand\"] }}. \n\nTopic: {{ $json.title }}\nMeta Description: {{ $json.description }}\nOutline: \nPrimary: {{ $json.primary }}\nSecondary:{{ $json.secondary }}\n\n\nWriting Guidelines:\n1. Tone: Professional, authoritative, yet accessible. Avoid corporate jargon where simple words work better.\n2. Structure: Use H1, H2, and H3 headers. Use bullet points for readability.\n3. EEAT: Include specific insights on how AI Automation and B2B SaaS growth intersect. \n4. Formatting: Write in clean Markdown.\n5. Goal: Solve a specific pain point for the reader (e.g., efficiency, scaling, or cost reduction).\n\n[Start Writing the Blog Post Below]",
        "hasOutputParser": true,
        "batching": {}
      },
